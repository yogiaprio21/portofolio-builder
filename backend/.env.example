NODE_ENV=development
PORT=3000

# Local development can use sqlite. Production should use the Neon Postgres URL.
DATABASE_URL=sqlite:./database.sqlite
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
PG_SSL=false

# Comma-separated frontend origins allowed to call this API.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Generate a strong value for production.
JWT_SECRET=replace-with-a-long-random-secret

# Render's filesystem is ephemeral unless a persistent disk is mounted.
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880
REQUIRE_UPLOAD_AUTH=false
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=cloudinary
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=portfolio-builder
JSON_BODY_LIMIT=1mb
TRUST_PROXY=
LOG_LEVEL=debug

# Auth cookie is sent alongside the JSON token for safer frontend migration later.
AUTH_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
REFRESH_TOKEN_DAYS=30
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false
JWT_EXPIRES_IN=7d
VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Email verification delivery. Use "log" locally, "resend" for production API, or "smtp" for Gmail/SMTP.
EMAIL_PROVIDER=log
EMAIL_FROM=Portfolio Builder <onboarding@resend.dev>
RESEND_API_KEY=
APP_URL=http://localhost:5173

# SMTP example for Gmail. Use a Google App Password, not your normal Gmail password.
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=Portfolio Builder <yourgmail@gmail.com>
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-character-app-password
# SMTP_REJECT_UNAUTHORIZED=true
# SMTP_EHLO_NAME=portfolio-builder.local

# Optional rate limit overrides.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=60
